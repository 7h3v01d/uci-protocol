{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://uci-spec.org/schemas/uci_audit_session_v0_1.json",
  "title": "UCI Audit Session v0.1",
  "description": "Canonical schema for a UCI audit session envelope. A portable, verifiable record of all lifecycle and governance events in a session.",
  "type": "object",
  "required": [
    "uci_audit_version",
    "session_id",
    "opened_at",
    "record_count",
    "records"
  ],
  "additionalProperties": true,
  "properties": {
    "uci_audit_version": {
      "type": "string",
      "enum": [
        "0.1"
      ]
    },
    "session_id": {
      "type": "string",
      "minLength": 1
    },
    "orchestrator_id": {
      "type": "string"
    },
    "opened_at": {
      "type": "string",
      "description": "ISO-8601 UTC timestamp when the session was opened."
    },
    "closed_at": {
      "oneOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "description": "ISO-8601 UTC timestamp when the session was sealed. Null if still open."
    },
    "session_hash": {
      "type": "string",
      "description": "SHA-256 of (session_id + tail record chain_hash). Empty if session is unsealed."
    },
    "record_count": {
      "type": "integer",
      "minimum": 0,
      "description": "Number of records in this session. Must match len(records)."
    },
    "records": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "event_id",
          "sequence",
          "event_type",
          "node_id",
          "timestamp",
          "chain_hash"
        ],
        "additionalProperties": true,
        "properties": {
          "event_id": {
            "type": "string",
            "minLength": 1
          },
          "sequence": {
            "type": "integer",
            "minimum": 1
          },
          "event_type": {
            "type": "string",
            "minLength": 1
          },
          "node_id": {
            "type": "string"
          },
          "timestamp": {
            "type": "string"
          },
          "actor": {
            "type": "string"
          },
          "outcome": {
            "type": "string"
          },
          "detail": {
            "type": "object"
          },
          "previous_hash": {
            "type": "string"
          },
          "chain_hash": {
            "type": "string",
            "minLength": 64,
            "maxLength": 64,
            "description": "SHA-256 chain hash sealing this record against the previous."
          },
          "audit_event_version": {
            "type": "string"
          },
          "correlation_id": {
            "type": "string"
          },
          "severity": {
            "type": "string",
            "enum": [
              "info",
              "low",
              "medium",
              "high",
              "critical"
            ]
          },
          "source": {
            "type": "object"
          }
        }
      }
    }
  }
}